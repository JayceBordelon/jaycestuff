# auth.jaycebordelon.com — centralized OAuth identity provider.
# Copy to .env and fill in. All required vars cause the service to log.Fatal on boot if missing.

# ---- Required ----

# Postgres connection for the auth DB (DO managed pool or direct).
AUTH_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/auth?sslmode=require

# Google OAuth client. Created in Google Cloud Console under "OAuth 2.0 Client IDs".
# The callback URL must be registered under "Authorized redirect URIs" there.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_CALLBACK_URL=https://auth.jaycebordelon.com/auth/google/callback

# Registered consumer apps. Each entry: {id, secret, name, redirect_uris[]}.
# Clients are upserted into the DB on every boot so updates here propagate on restart.
# Keep the JSON compact on a single line. Secrets here MUST match what each
# consumer app passes via its own VT_AUTH_CLIENT_SECRET (or equivalent).
OAUTH_CLIENTS_JSON=[{"id":"vibetradez","secret":"CHANGE_ME_STRONG_RANDOM","name":"VibeTradez","redirect_uris":["https://vibetradez.com/auth/sso/callback"]}]

# ---- Optional ----

# HTTP port the service listens on inside its container. Traefik routes
# auth.jaycebordelon.com to this port on the Docker network.
AUTH_SERVER_PORT=8081

# Cookie the IdP sets on auth.jaycebordelon.com after a successful Google
# sign-in so a second consumer app doesn't re-prompt Google. Host-scoped.
IDP_COOKIE_NAME=aj_session
IDP_COOKIE_TTL_DAYS=30

# One-shot authorization code lifetime (seconds). Tight is safer.
AUTH_CODE_TTL_SECONDS=60

# Access token lifetime (days). Consumers re-verify via /oauth/verify on each
# request and cache for 60s, so shorter TTL here = faster revocation propagation.
ACCESS_TOKEN_TTL_DAYS=30
