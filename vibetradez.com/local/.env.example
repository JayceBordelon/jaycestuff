# Local dev overrides for docker-compose.local.yml. Copy to .env and fill in
# if you want to test real Google sign-in against the local auth-service.
# Without these, the stack still boots — auth-service uses stub values and
# the /auth/google flow returns 400 from Google, which is fine unless you're
# exercising the sign-in path.
#
# Compose reads .env automatically from this directory.

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# The local auth-service registers this callback with Google (see
# docker-compose.local.yml auth-service env). If you change the port or
# path here, update GOOGLE_CALLBACK_URL there too.
#   GOOGLE_CALLBACK_URL=http://localhost:8081/auth/google/callback
